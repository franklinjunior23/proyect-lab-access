generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        Int         @id @default(autoincrement())
  name      String
  uid       String      @unique
  active    Boolean     @default(true)
  createdAt DateTime    @default(now())
  accesses  AccessLog[]
}

model AccessLog {
  id          Int      @id @default(autoincrement())
  uid         String
  result      Result
  description String?
  timestamp   DateTime @default(now())
  userId      Int?
  user        User?    @relation(fields: [userId], references: [id])

  @@index([timestamp])
  @@index([result])
  @@index([userId])
}

enum Result {
  ACCESS_GRANTED
  ACCESS_DENIED
}

model AdminUser {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}
